# Supabase Configuration
# Retrieve these from Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-secret-key

# WorkOS Authentication Configuration
# Retrieve these from WorkOS Dashboard
WORKOS_API_KEY=your-workos-api-key
WORKOS_CLIENT_ID=your-workos-client-id
# For Local Development: http://localhost:3000/api/auth/callback
# For Staging: https://staging.app.analyzehive.com/api/auth/callback
WORKOS_REDIRECT_URI=your-workos-redirect-uri

# Sensy WhatsApp API Configuration
# Optional: Retrieve from Sensy Dashboard if active, otherwise use these mocks
SENSY_API_URL=https://api.sensy.example.com/send
SENSY_API_KEY=mock-api-key
NEXT_PUBLIC_BROCHURE_URL=https://example.com/brochure.pdf
INTERNAL_BROKER_PHONE=+910000000000

# Security secrets
CRON_SECRET=your-random-cron-secret-key
